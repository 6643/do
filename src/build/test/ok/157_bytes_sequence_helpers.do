bytes_contains = @lib("bytes.do", contains)
bytes_copy = @lib("bytes.do", copy)
bytes_ends_with = @lib("bytes.do", ends_with)
bytes_first = @lib("bytes.do", first)
bytes_first_or = @lib("bytes.do", first_or)
bytes_index_of = @lib("bytes.do", index_of)
bytes_is_empty = @lib("bytes.do", is_empty)
bytes_last = @lib("bytes.do", last)
bytes_last_index_of = @lib("bytes.do", last_index_of)
bytes_last_or = @lib("bytes.do", last_or)
bytes_repeat_byte = @lib("bytes.do", repeat_byte)
bytes_replace = @lib("bytes.do", replace)
bytes_starts_with = @lib("bytes.do", starts_with)

test "bytes sequence helpers" {
    bytes [u8] = "  abc abc  "
    empty [u8] = ""
    first_value, first_ok = bytes_first_or("abc", 0)
    missing_first, missing_first_ok = bytes_first_or(empty, 9)
    last_value, last_ok = bytes_last_or("abc", 0)
    missing_last, missing_last_ok = bytes_last_or(empty, 9)

    ok bool = true
    ok = @and(ok, bytes_is_empty(empty))
    ok = @and(ok, @not(bytes_is_empty(bytes)))
    ok = @and(ok, @eq(bytes_copy("abc"), "abc"))
    ok = @and(ok, @eq(bytes_repeat_byte(120, 3), "xxx"))
    ok = @and(ok, bytes_starts_with(bytes, "  a"))
    ok = @and(ok, bytes_ends_with(bytes, "  "))
    ok = @and(ok, bytes_contains(bytes, "bc a"))
    ok = @and(ok, @not(bytes_contains(bytes, "zzz")))
    ok = @and(ok, @eq(bytes_index_of(bytes, "abc"), 2))
    ok = @and(ok, @eq(bytes_last_index_of(bytes, "abc"), 6))
    ok = @and(ok, @eq(bytes_index_of(bytes, "zzz"), nil))
    ok = @and(ok, @eq(bytes_last_index_of(bytes, "zzz"), nil))
    ok = @and(ok, @eq(bytes_replace("one two two", "two", "2"), "one 2 2"))
    ok = @and(ok, @eq(bytes_replace("abc", "", "x"), "abc"))
    ok = @and(ok, @eq(bytes_first("abc"), 97))
    ok = @and(ok, first_ok)
    ok = @and(ok, @eq(first_value, 97))
    ok = @and(ok, @not(missing_first_ok))
    ok = @and(ok, @eq(missing_first, 9))
    ok = @and(ok, @eq(bytes_last("abc"), 99))
    ok = @and(ok, last_ok)
    ok = @and(ok, @eq(last_value, 99))
    ok = @and(ok, @not(missing_last_ok))
    ok = @and(ok, @eq(missing_last, 9))
    if ok return
}
