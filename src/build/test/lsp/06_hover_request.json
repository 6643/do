{
  "name": "hover request",
  "messages": [
    {
      "jsonrpc": "2.0",
      "method": "initialize",
      "id": 1,
      "params": {
        "capabilities": {}
      }
    },
    {
      "jsonrpc": "2.0",
      "method": "textDocument/didOpen",
      "params": {
        "textDocument": {
          "uri": "file:///tmp/do-lsp-hover.do",
          "languageId": "do",
          "version": 1,
          "text": "User {\n    title text\n}\nget_title(user User) -> text {\n    title text = @get(user, .title)\n    return title\n}\n"
        }
      }
    },
    {
      "jsonrpc": "2.0",
      "method": "textDocument/hover",
      "id": 2,
      "params": {
        "textDocument": {
          "uri": "file:///tmp/do-lsp-hover.do"
        },
        "position": {
          "line": 3,
          "character": 3
        }
      }
    },
    {
      "jsonrpc": "2.0",
      "method": "shutdown",
      "id": 3,
      "params": null
    },
    {
      "jsonrpc": "2.0",
      "method": "exit",
      "params": null
    }
  ],
  "expect": [
    "\"hoverProvider\":true",
    "\"result\":{\"contents\":{\"kind\":\"plaintext\",\"value\":\"get_title(user User) -> text\"}}"
  ]
}
