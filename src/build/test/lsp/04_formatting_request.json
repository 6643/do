{
  "name": "formatting request",
  "messages": [
    {
      "jsonrpc": "2.0",
      "method": "initialize",
      "id": 1,
      "params": {
        "capabilities": {}
      }
    },
    {
      "jsonrpc": "2.0",
      "method": "textDocument/didOpen",
      "params": {
        "textDocument": {
          "uri": "file:///tmp/do-lsp-formatting.do",
          "languageId": "do",
          "version": 1,
          "text": "User {\nid i32\n}"
        }
      }
    },
    {
      "jsonrpc": "2.0",
      "method": "textDocument/formatting",
      "id": 2,
      "params": {
        "textDocument": {
          "uri": "file:///tmp/do-lsp-formatting.do",
          "version": 1
        },
        "options": {
          "tabSize": 4,
          "insertSpaces": true
        }
      }
    },
    {
      "jsonrpc": "2.0",
      "method": "shutdown",
      "id": 3,
      "params": null
    },
    {
      "jsonrpc": "2.0",
      "method": "exit",
      "params": null
    }
  ],
  "expect": [
    "\"documentFormattingProvider\":true",
    "\"newText\":\"User {\\n    id i32\\n}\\n\""
  ]
}
