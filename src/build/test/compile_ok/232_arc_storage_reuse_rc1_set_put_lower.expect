;; arc-runtime storage write helpers v1
(func $__storage_set_u8
(func $__storage_put_u8
count=2 call $__arc_rc
count=0 call $__arc_inc
count=1 call $__storage_set_u8
count=1 call $__storage_put_u8
count=2 ;; arc-overwrite-release data
local.get $data
i32.const 1
i32.const 90
call $__storage_set_u8
local.get $data
i32.const 33
call $__storage_put_u8
