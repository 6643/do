(func $make_outer (result i32 i32 i32)
local.get $outer.v0.v0
local.get $outer.v0.v1
local.get $outer.v1
return
(func $pick_flag (param $outer.v0.v0 i32) (param $outer.v0.v1 i32) (param $outer.v1 i32) (result i32)
call $make_outer
local.set $outer.v1
local.set $outer.v0.v1
local.set $outer.v0.v0
call $pick_flag
